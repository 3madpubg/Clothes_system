PORT=5000
DATABASE_URL="postgresql://postgres:password@localhost:5432/shop_system?schema=public"
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
# Optional. Set only when the frontend is hosted on a different origin.
CORS_ORIGIN="http://localhost:3000"

# Used only to bootstrap the first admin account with npm run seed.
SEED_ADMIN_NAME="System Admin"
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="replace-with-a-strong-password"
